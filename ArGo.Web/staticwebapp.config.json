{
  "navigationFallback": {
    "rewrite": "/index.html"
  },
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": [
        "anonymous",
        "authenticated"
      ]
    },
    {
      "route": "/app*",
      "rewrite": "/index.html"
    },
    {
      "route": "/api/:shortCode",
      "methods": [
        "get"
      ],
      "redirect": "https://ar-go-arhse0cmgba4h9cg.eastasia-01.azurewebsites.net/api/:shortCode",
      "statusCode": 302
    }
  ]
}