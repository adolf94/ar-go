{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/static/media/*",
      "/favicon.ico",
      "/*.{png,jpg,jpeg,gif,svg,js,css,ico}"
    ]
  },
  "routes": [
    {
      "route": "/:shortCode",
      "rewrite": "/api/redirect/:shortCode",
      "methods": [
        "GET"
      ]
    }
  ]
}