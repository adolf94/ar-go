{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/static/media/*",
      "/favicon.ico",
      "/*.{png,jpg,jpeg,gif,svg,js,css,ico}"
    ]
  },
  "routes": [
    {
      "route": "/app*",
      "rewrite": "/index.html"
    },
    {
      "route": "/api/*",
      "allowedRoles": [
        "anonymous",
        "authenticated"
      ]
    },
    {
      "route": "^/(?!app)([^/.]+)$",
      "redirect": "/api/redirect/$1",
      "statusCode": 302
    }
  ]
}