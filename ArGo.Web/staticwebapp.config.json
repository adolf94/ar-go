{
  "navigationFallback": {
    "rewrite": "/index.html"
  },
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous", "authenticated"]
    },
    {
      "route": "/app",
      "rewrite": "/index.html"
    },
    {
      "route": "/:shortCode",
      "redirect": "https://<your-functions-app>.azurewebsites.net/api/:shortCode",
      "statusCode": 302,
      "methods": [
        "GET"
      ]
    }
  ]
}
